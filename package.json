{
    "name": "@elizaos-plugins/plugin-icp",
    "version": "0.1.9",
    "description": "ICP Toolkit — ElizaOS plugin for the Internet Computer: wallet, Launchpad registry, ICRC-1, and T3kNo-Logic ecosystem actions.",
    "type": "module",
    "author": "T3kNo-Logic (https://github.com/T3kNoLogic)",
    "license": "MIT",
    "keywords": [
        "internet-computer",
        "icp",
        "dfinity",
        "elizaos",
        "eliza",
        "milady",
        "icrc-1",
        "canister",
        "plug-wallet",
        "t3kno-logic",
        "milady-icp-toolkit"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/T3kNoLogic/milady-icp-toolkit.git"
    },
    "bugs": {
        "url": "https://github.com/T3kNoLogic/plugin-icp-toolkit/issues"
    },
    "homepage": "https://github.com/T3kNoLogic/milady-icp-toolkit#readme",
    "main": "dist/index.js",
    "module": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        "./package.json": "./package.json",
        ".": {
            "import": {
                "@elizaos/source": "./src/index.ts",
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "files": [
        "dist"
    ],
    "dependencies": {
        "@elizaos/core": "next",
        "@dfinity/agent": "2.1.3",
        "@dfinity/candid": "2.1.3",
        "@dfinity/identity": "2.1.3",
        "@dfinity/principal": "2.1.3"
    },
    "scripts": {
        "build": "tsup --format esm --dts",
        "dev": "tsup --format esm --dts --watch",
        "lint": "eslint --fix  --cache ."
    },
    "devDependencies": {
        "@types/jest": "29.5.14",
        "jest": "29.7.0",
        "tsup": "8.3.5",
        "typescript": "5.6.3"
    },
    "agentConfig": {
        "pluginType": "elizaos:client:1.0.0",
        "pluginParameters": {
            "INTERNET_COMPUTER_PRIVATE_KEY": {
                "type": "string",
                "minLength": 1,
                "description": "Internet Computer private key for authentication"
            }
        }
    }
}